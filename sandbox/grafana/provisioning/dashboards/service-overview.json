{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2, "spanNulls": false },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(rate({__name__=~\".+_http_requests_total\", service=~\"$service\"}[$__rate_interval])) by (service)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Rate (4xx / 5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2, "spanNulls": false },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(rate({__name__=~\".+_http_requests_total\", service=~\"$service\", status_code=~\"5..\"}[$__rate_interval])) by (service)",
          "legendFormat": "{{service}} 5xx",
          "refId": "A"
        },
        {
          "expr": "sum(rate({__name__=~\".+_http_requests_total\", service=~\"$service\", status_code=~\"4..\"}[$__rate_interval])) by (service)",
          "legendFormat": "{{service}} 4xx",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Response Time (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 5, "lineWidth": 2, "spanNulls": false },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate({__name__=~\".+_http_request_duration_seconds_bucket\", service=~\"$service\"}[$__rate_interval])) by (le, service))",
          "legendFormat": "{{service}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate({__name__=~\".+_http_request_duration_seconds_bucket\", service=~\"$service\"}[$__rate_interval])) by (le, service))",
          "legendFormat": "{{service}} p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate({__name__=~\".+_http_request_duration_seconds_bucket\", service=~\"$service\"}[$__rate_interval])) by (le, service))",
          "legendFormat": "{{service}} p99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Error Rate %",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "100 * sum(rate({__name__=~\".+_http_requests_total\", service=~\"$service\", status_code=~\"5..\"}[$__rate_interval])) / (sum(rate({__name__=~\".+_http_requests_total\", service=~\"$service\"}[$__rate_interval])) > 0) or vector(0)",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Request Rate (total)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(rate({__name__=~\".+_http_requests_total\", service=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Request Duration by Route",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #p99" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "displayName", "value": "p99" },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 0.5 },
                  { "color": "red", "value": 1 }
                ]
              }},
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #p95" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "displayName", "value": "p95" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #rate" },
            "properties": [
              { "id": "unit", "value": "reqps" },
              { "id": "displayName", "value": "rate" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "rate", "desc": true }]
      },
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "le": true, "__name__": true }
          }
        }
      ],
      "targets": [
        {
          "expr": "sum(rate({__name__=~\".+_http_requests_total\", service=~\"$service\"}[$__rate_interval])) by (route, method)",
          "refId": "rate",
          "format": "table",
          "instant": true
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate({__name__=~\".+_http_request_duration_seconds_bucket\", service=~\"$service\"}[$__rate_interval])) by (le, route, method))",
          "refId": "p95",
          "format": "table",
          "instant": true
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate({__name__=~\".+_http_request_duration_seconds_bucket\", service=~\"$service\"}[$__rate_interval])) by (le, route, method))",
          "refId": "p99",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "title": "Status Code Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(increase({__name__=~\".+_http_requests_total\", service=~\"$service\"}[5m])) by (status_code)",
          "legendFormat": "{{status_code}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "title": "Top 5 Slowest Routes (p95)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.25 },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "topk(5, histogram_quantile(0.95, sum(rate({__name__=~\".+_http_request_duration_seconds_bucket\", service=~\"$service\"}[$__rate_interval])) by (le, route)))",
          "legendFormat": "{{route}}",
          "refId": "A",
          "instant": true
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["observability", "http", "red"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values({__name__=~\".+_http_requests_total\"}, service)",
        "includeAll": true,
        "multi": true,
        "name": "service",
        "query": { "query": "label_values({__name__=~\".+_http_requests_total\"}, service)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Service Overview (RED)",
  "uid": "service-overview-red"
}
