{
  "name": "@ivymurage-rw/observability",
  "version": "0.1.3",
  "description": "Internal observability platform SDK for NestJS distributed services",
  "repository": {
    "type": "git",
    "url": "https://github.com/ivymurage-rw/internal-observability-platform.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pino": "^9.0.0",
    "prom-client": "^15.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-node": "^1.25.0",
    "@opentelemetry/sdk-trace-base": "^1.25.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.52.0",
    "@opentelemetry/instrumentation": "^0.52.0",
    "@opentelemetry/instrumentation-http": "^0.52.0",
    "@opentelemetry/resources": "^1.25.0",
    "@opentelemetry/semantic-conventions": "^1.25.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.1.0 || ^0.2.0",
    "rxjs": "^7.0.0",
    "ioredis": "^5.0.0",
    "kafkajs": "^2.0.0",
    "mysql2": "^3.0.0",
    "pg": "^8.0.0",
    "@opentelemetry/instrumentation-ioredis": ">=0.40.0",
    "@opentelemetry/instrumentation-kafkajs": ">=0.1.0",
    "@opentelemetry/instrumentation-mysql2": ">=0.38.0",
    "@opentelemetry/instrumentation-pg": ">=0.41.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    },
    "kafkajs": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "@opentelemetry/instrumentation-ioredis": {
      "optional": true
    },
    "@opentelemetry/instrumentation-kafkajs": {
      "optional": true
    },
    "@opentelemetry/instrumentation-mysql2": {
      "optional": true
    },
    "@opentelemetry/instrumentation-pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0",
    "typescript": "^5.5.0",
    "tsup": "^8.0.0",
    "vitest": "^2.0.0",
    "pino-pretty": "^11.0.0"
  }
}
